{
  "version": "1.0",
  "description": "Frontend env file registry — see lib/config/env_files_config.dart",
  "files": {
    ".env": {
      "gitignored": true,
      "purpose": "local development (KEY=value)",
      "template": ".env.example"
    },
    "env.production.json": {
      "gitignored": true,
      "purpose": "release build: flutter build --dart-define-from-file=env.production.json",
      "template": "env.production.example.json"
    },
    "env.local.json": {
      "gitignored": true,
      "purpose": "optional dart-define overlay for flutter run",
      "template": null
    },
    "assets/env.defaults": {
      "gitignored": false,
      "purpose": "bundled dev defaults loaded at runtime"
    },
    "assets/env.local": {
      "gitignored": true,
      "purpose": "runtime overlay generated from .env",
      "generated_by": "dart run tool/sync_env.dart"
    },
    "android/secrets.properties": {
      "gitignored": true,
      "purpose": "Gradle GOOGLE_MAPS_API_KEY at build time",
      "generated_by": "dart run tool/sync_env.dart"
    },
    "android/app/google-services.local.json": {
      "gitignored": true,
      "purpose": "Firebase Android native config (package com.meatvo.app)"
    },
    "android/app/google-services.json": {
      "gitignored": true,
      "purpose": "build-time copy of google-services.local.json"
    },
    "android/keystore.properties": {
      "gitignored": true,
      "purpose": "release APK signing credentials"
    }
  },
  "load_priority": [
    "--dart-define / env.production.json",
    "assets/env.local",
    "assets/env.defaults"
  ],
  "sync_keys": [
    "APP_ENV",
    "API_BASE_URL",
    "GOOGLE_MAPS_API_KEY",
    "FIREBASE_API_KEY",
    "FIREBASE_APP_ID",
    "FIREBASE_MESSAGING_SENDER_ID",
    "FIREBASE_PROJECT_ID",
    "FIREBASE_STORAGE_BUCKET",
    "MEATVO_API_ROOT",
    "BACKEND_ROOT_URL",
    "API_URL",
    "CASHFREE_ENV"
  ],
  "variables": {
    "API_BASE_URL": {
      "required": "production",
      "client_safe": true,
      "files": [".env", "env.production.json"]
    },
    "MEATVO_API_ROOT": {
      "required": "optional",
      "client_safe": true,
      "files": [".env", "env.production.json"]
    },
    "APP_ENV": {
      "required": "production",
      "default": "development",
      "client_safe": true
    },
    "CASHFREE_ENV": {
      "required": "production",
      "default": "sandbox",
      "client_safe": true
    },
    "GOOGLE_MAPS_API_KEY": {
      "required": "production",
      "client_safe": true,
      "files": [".env", "env.production.json", "android/secrets.properties"]
    },
    "FIREBASE_API_KEY": {
      "required": "production",
      "client_safe": true
    },
    "FIREBASE_APP_ID": {
      "required": "production",
      "client_safe": true
    },
    "FIREBASE_PROJECT_ID": {
      "required": "production",
      "client_safe": true
    },
    "FIREBASE_MESSAGING_SENDER_ID": {
      "required": "production",
      "client_safe": true
    },
    "FIREBASE_STORAGE_BUCKET": {
      "required": "production",
      "client_safe": true
    },
    "SENTRY_DSN": {
      "required": "optional",
      "client_safe": true
    }
  },
  "never_in_client": [
    "JWT_ACCESS_SECRET",
    "JWT_REFRESH_SECRET",
    "OTP_HASH_SECRET",
    "CASHFREE_SECRET_KEY",
    "FCM_SERVER_KEY",
    "FIREBASE_SERVICE_ACCOUNT_JSON",
    "DB_PASSWORD"
  ]
}
