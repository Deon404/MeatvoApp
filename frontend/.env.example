# Local development — NOT bundled in release APK.
# Physical device: copy this file to assets/env.local, then flutter run (full restart).
# Use: flutter run --dart-define-from-file=env.local.json
# Or:  flutter run --dart-define=API_BASE_URL=http://10.0.2.2:8080

APP_ENV=development

# Backend API root (required for production builds via --dart-define)
# Physical phone on same Wi‑Fi: your PC LAN IP (ipconfig → IPv4)
API_BASE_URL=http://10.0.2.2:8080

# Google Maps — also set in android/gradle.properties for native tiles
GOOGLE_MAPS_API_KEY=your_key_here

# Auth API paths
API_AUTH_SEND_OTP_PATH=/auth/send-otp
API_AUTH_VERIFY_OTP_PATH=/auth/verify-otp
API_AUTH_REFRESH_PATH=/auth/refresh
API_AUTH_REFRESH_TOKEN_PATH=/auth/refresh-token

# Secure storage key names (not JWT values)
SECURE_STORAGE_ACCESS_TOKEN_KEY=access_token
SECURE_STORAGE_REFRESH_TOKEN_KEY=refresh_token
SECURE_STORAGE_USER_DATA_KEY=user_data
SECURE_STORAGE_USER_ROLE_KEY=user_role
SECURE_STORAGE_USER_ID_KEY=user_id

# Optional
MERCHANT_PHONE_NUMBER=
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_MESSAGING_SENDER_ID=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# Production release build:
# flutter build appbundle --release --dart-define-from-file=env.production.json
