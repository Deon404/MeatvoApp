# Local development — NOT bundled in release APK. GITIGNORED — never commit.
# Registry: env.manifest.json | lib/config/env_files_config.dart
# Validate: dart run tool/validate_env.dart
#
# Physical device: dart run tool/sync_env.dart (writes assets/env.local)
# Or: flutter run --dart-define-from-file=env.local.json
# Or: flutter run --dart-define=API_BASE_URL=http://10.0.2.2:8080

APP_ENV=development

# Backend API root (required for production builds via --dart-define)
# Physical phone on same Wi‑Fi: your PC LAN IP (ipconfig → IPv4)
API_BASE_URL=http://10.0.2.2:8080

# Google Maps — synced to android/secrets.properties by tool/sync_env.dart
GOOGLE_MAPS_API_KEY=your_key_here

# Firebase (Flutter runtime + copy values into google-services.local.json for Gradle)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_APP_ID=1:YOUR_PROJECT_NUMBER:android:YOUR_APP_HASH
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_MESSAGING_SENDER_ID=YOUR_PROJECT_NUMBER
FIREBASE_STORAGE_BUCKET=your-firebase-project-id.firebasestorage.app

# Auth API paths
API_AUTH_SEND_OTP_PATH=/auth/send-otp
API_AUTH_VERIFY_OTP_PATH=/auth/verify-otp
API_AUTH_REFRESH_PATH=/auth/refresh
API_AUTH_REFRESH_TOKEN_PATH=/auth/refresh-token

# Secure storage key names (not JWT values)
SECURE_STORAGE_ACCESS_TOKEN_KEY=access_token
SECURE_STORAGE_REFRESH_TOKEN_KEY=refresh_token
SECURE_STORAGE_USER_DATA_KEY=user_data
SECURE_STORAGE_USER_ROLE_KEY=user_role
SECURE_STORAGE_USER_ID_KEY=user_id

# Optional
MERCHANT_PHONE_NUMBER=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# Production release (env.production.json is GITIGNORED — copy from example):
#   cp env.production.example.json env.production.json
#   dart run tool/validate_env.dart --production
#   cd frontend && .\scripts\build-apk-production.ps1
# Or manually:
#   flutter build apk --release --dart-define-from-file=env.production.json
# Play Store (App Bundle):
#   flutter build appbundle --release --dart-define-from-file=env.production.json
