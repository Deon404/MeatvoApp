# Copy to android/keystore.properties (gitignored) or set MEATVO_* env vars for CI.
# MEATVO_KEYSTORE_PATH=/path/to/meatvo-upload-key.jks
# MEATVO_KEYSTORE_PASSWORD=your_store_password
# MEATVO_KEY_ALIAS=meatvo
# MEATVO_KEY_PASSWORD=your_key_password
#
# PowerShell (quote passwords — # starts a comment otherwise):
#   $env:MEATVO_KEYSTORE_PATH = 'C:\path\to\meatvo-upload-key.jks'
#   $env:MEATVO_KEYSTORE_PASSWORD = 'your_store_password'
#   $env:MEATVO_KEY_ALIAS = 'meatvo'
#   $env:MEATVO_KEY_PASSWORD = 'your_key_password'
#   flutter build appbundle --release
