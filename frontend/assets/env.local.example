# Copy to assets/env.local (gitignored) before flutter run on a physical device.
# Quick sync: dart run tool/sync_env.dart
# Physical phone on Wi‑Fi: set API_BASE_URL to your PC LAN IP (ipconfig → IPv4).
# Android emulator: http://10.0.2.2:8080
# USB + adb reverse tcp:8080 tcp:8080: http://127.0.0.1:8080

APP_ENV=development
API_BASE_URL=http://YOUR_PC_LAN_IP:8080
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
SENTRY_DSN=https://your-key@o000000.ingest.us.sentry.io/0000000
SENTRY_TRACES_SAMPLE_RATE=0.2
