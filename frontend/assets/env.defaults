# Bundled dev defaults — Flutter reads this at runtime (not frontend/.env).
# USB phone (recommended): run frontend/scripts/dev-android.ps1 (sets adb reverse).
#   API_BASE_URL=http://127.0.0.1:8080
# Wi‑Fi phone: set API_BASE_URL to PC LAN IP (ipconfig → Wi‑Fi IPv4), run setup-firewall.ps1 as admin.
# Android emulator: http://10.0.2.2:8080

APP_ENV=development
API_BASE_URL=http://127.0.0.1:8080
