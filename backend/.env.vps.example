# VPS production template — copy to .env on server and fill secrets.
# cp .env.vps.example .env && nano .env

NODE_ENV=production
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info
TRUST_PROXY=true
ENFORCE_HTTPS=false

# PostgreSQL (Phase 1 defaults)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=meatvo_db
DB_USER=meatvo_user
DB_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://meatvo_user:CHANGE_ME@127.0.0.1:5432/meatvo_db

# Redis (set password from MEATVO_REDIS_PASSWORD in Phase 1 setup)
REDIS_URL=redis://:CHANGE_ME@127.0.0.1:6379
REDIS_ENCRYPTION_KEY=
PAYMENT_ENCRYPTION_KEY=

# JWT / OTP
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=30m
JWT_REFRESH_EXPIRY=10d
OTP_HASH_SECRET=
MFA_ENCRYPTION_KEY=
UPLOAD_SIGNING_SECRET=
UPLOAD_SIGN_TTL_SECONDS=604800
OTP_LENGTH=6
OTP_LOG_TO_CONSOLE=false

# MSG91 (runtime uses MSG91_AUTH_KEY)
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_OTP_TEMPLATE_ID=
MSG91_SENDER_ID=MEATVO
MSG91_OTP_LENGTH=6
MSG91_SKIP_BALANCE_CHECK=true

# PhonePe (deprecated — kept for reference)
# PHONEPE_MERCHANT_ID=
# PHONEPE_SALT_KEY=
# PHONEPE_SALT_INDEX=1
# PHONEPE_REDIRECT_URL=https://YOUR_DOMAIN/payment/return
# PHONEPE_WEBHOOK_URL=https://YOUR_DOMAIN/api/payments/phonepe/webhook

# Cashfree Payment Gateway
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_API_BASE=https://api.cashfree.com/pg
CASHFREE_RETURN_URL=https://yourdomain.com/api/payments/cashfree/verify
CASHFREE_WEBHOOK_URL=https://yourdomain.com/api/payments/cashfree/webhook

# Maps / Firebase
GOOGLE_MAPS_API_KEY=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_VAPID_KEY=

# Sentry — required in production (real project DSN from sentry.io)
SENTRY_DSN=

# Rate limiting — never disable in production
# DISABLE_API_RATE_LIMIT=false
# COUPON_RATE_LIMIT_MAX=30

# Redis — must use real Redis in production (no in-memory fallback)
# REDIS_ALLOW_FALLBACK=false

# CORS — use HTTPS domain after SSL
CORS_ORIGINS=https://YOUR_DOMAIN
CORS_ALLOW_NULL_ORIGIN=false

DEFAULT_COUNTRY_CODE=+91
DEV_AUTH_BYPASS_ENABLED=false
METRICS_ALLOWED_IPS=127.0.0.1
