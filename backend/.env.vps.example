# VPS production template — copy to .env on server and fill secrets.
# cp .env.vps.example .env && nano .env

NODE_ENV=production
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info
TRUST_PROXY=true
ENFORCE_HTTPS=false

# PostgreSQL (Phase 1 defaults)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=meatvo_db
DB_USER=meatvo_user
DB_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://meatvo_user:CHANGE_ME@127.0.0.1:5432/meatvo_db

# Redis (set password from MEATVO_REDIS_PASSWORD in Phase 1 setup)
REDIS_URL=redis://:CHANGE_ME@127.0.0.1:6379
REDIS_ENCRYPTION_KEY=
PAYMENT_ENCRYPTION_KEY=

# JWT / OTP
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=30m
JWT_REFRESH_EXPIRY=10d
OTP_HASH_SECRET=
OTP_LENGTH=6
OTP_LOG_TO_CONSOLE=false

# MSG91 (runtime uses MSG91_AUTH_KEY)
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_OTP_TEMPLATE_ID=
MSG91_SENDER_ID=MEATVO
MSG91_OTP_LENGTH=6
MSG91_SKIP_BALANCE_CHECK=true

# PhonePe — use HTTPS URLs after Phase 3 SSL
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=1
PHONEPE_REDIRECT_URL=https://YOUR_DOMAIN/payment/return
PHONEPE_WEBHOOK_URL=https://YOUR_DOMAIN/api/payments/phonepe/webhook

# Maps / Firebase
GOOGLE_MAPS_API_KEY=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_VAPID_KEY=

# Sentry — use real DSN in production
SENTRY_DSN=https://placeholder@o0.ingest.sentry.io/0

# CORS — use HTTPS domain after SSL
CORS_ORIGINS=https://YOUR_DOMAIN
CORS_ALLOW_NULL_ORIGIN=false

DEFAULT_COUNTRY_CODE=+91
DEV_AUTH_BYPASS_ENABLED=false
METRICS_ALLOWED_IPS=127.0.0.1
