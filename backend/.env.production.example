# Production environment — copy to .env on VPS and fill all secrets.
# cp .env.production.example .env && nano .env
# See also: .env.vps.example (Hostinger KVM template with inline comments)

NODE_ENV=production
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info
TRUST_PROXY=true
ENFORCE_HTTPS=true

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=meatvo_db
DB_USER=meatvo_user
DB_PASSWORD=
DATABASE_URL=postgresql://meatvo_user:PASSWORD@127.0.0.1:5432/meatvo_db

# Redis (password required in production)
REDIS_URL=redis://:PASSWORD@127.0.0.1:6379

# JWT / OTP
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=30m
JWT_REFRESH_EXPIRY=10d
OTP_HASH_SECRET=
MFA_ENCRYPTION_KEY=
UPLOAD_SIGNING_SECRET=
UPLOAD_SIGN_TTL_SECONDS=604800
OTP_LENGTH=6
MSG91_OTP_LENGTH=6
OTP_LOG_TO_CONSOLE=false

# SMS (MSG91)
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_OTP_TEMPLATE_ID=
MSG91_SENDER_ID=MEATVO



# Cashfree Payment Gateway
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_API_BASE=https://api.cashfree.com/pg
CASHFREE_RETURN_URL=https://yourdomain.com/api/payments/cashfree/verify
CASHFREE_WEBHOOK_URL=https://yourdomain.com/api/payments/cashfree/webhook

# Maps / Firebase
GOOGLE_MAPS_API_KEY=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_VAPID_KEY=

# Monitoring
SENTRY_DSN=

# CORS
CORS_ORIGINS=https://YOUR_DOMAIN
CORS_ALLOW_NULL_ORIGIN=false

# Security
DEFAULT_COUNTRY_CODE=+91
DEV_AUTH_BYPASS_ENABLED=false
METRICS_ALLOWED_IPS=127.0.0.1

# PM2 (optional)
PM2_INSTANCES=1
PM2_MAX_MEMORY=512M
