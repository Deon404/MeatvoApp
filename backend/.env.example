# Production environment template — copy to .env and fill in secrets.
# Never commit .env with real credentials.
# Full production template: .env.production.example

NODE_ENV=development
PORT=8080
HOST=0.0.0.0
TRUST_PROXY=true
ENFORCE_HTTPS=false

DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=meatvo_db
DB_USER=meatvo_user
DB_PASSWORD=

REDIS_URL=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
# Generate: openssl rand -hex 32 (min 32 chars; dev-default values are rejected at startup)
OTP_HASH_SECRET=
MFA_ENCRYPTION_KEY=
UPLOAD_SIGNING_SECRET=
UPLOAD_SIGN_TTL_SECONDS=604800
OTP_LENGTH=6

MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_OTP_TEMPLATE_ID=
MSG91_SENDER_ID=MEATVO
SMS_PROVIDER=msg91

# PHONEPE_MERCHANT_ID=
# PHONEPE_SALT_KEY=
# PHONEPE_SALT_INDEX=1
# PHONEPE_REDIRECT_URL=
# PHONEPE_WEBHOOK_URL=

# Cashfree Payment Gateway
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_API_BASE=https://sandbox.cashfree.com/pg
CASHFREE_RETURN_URL=http://localhost:8080/api/payments/cashfree/verify
CASHFREE_WEBHOOK_URL=http://localhost:8080/api/payments/cashfree/webhook

GOOGLE_MAPS_API_KEY=
FIREBASE_API_KEY=
FIREBASE_VAPID_KEY=
SENTRY_DSN=

CORS_ORIGINS=
CORS_ALLOW_NULL_ORIGIN=false
METRICS_ALLOWED_IPS=127.0.0.1
DEV_AUTH_BYPASS_ENABLED=false
OTP_LOG_TO_CONSOLE=false
