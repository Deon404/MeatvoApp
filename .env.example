# Root env for Docker Compose (copy to .env:  copy .env.example .env)
# Values should match backend/.env where applicable.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=meatvo

JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
OTP_HASH_SECRET=change_me_otp_hash_secret

SMS_PROVIDER=console
DEV_AUTH_BYPASS_ENABLED=false
DEV_AUTH_BYPASS_SECRET=

# Comma-separated allowed CORS origins (defaults to http://localhost:3000 if unset)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Firebase web push (admin panel FCM)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
FIREBASE_VAPID_KEY=
